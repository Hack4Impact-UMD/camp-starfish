rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == "ADMIN";
    }

    function isStaff() {
      return isAuthenticated() && request.auth.token.role == "STAFF";
    }

    function isStaffOrAdmin() {
      return isStaff() || isAdmin();
    }

    function isParent() {
      return isAuthenticated() && request.auth.token.role == "PARENT";
    }

    function isPhotographer() {
      return isAuthenticated() && request.auth.token.role == "PHOTOGRAPHER";
    }

    // The signed-in user's CampMinder id (their /users doc id), as a string.
    function myCampminderId() {
      return string(request.auth.token.campminderId);
    }

    // The camper ids belonging to the signed-in parent.
    function myCamperIds() {
      return get(/databases/$(database)/documents/users/$(myCampminderId())).data.camperIds;
    }

    // Whether the given session includes one of the signed-in parent's campers.
    function sessionHasMyCamper(sessionId) {
      return exists(/databases/$(database)/documents/sessions/$(sessionId))
        && 'attendeeIds' in get(/databases/$(database)/documents/sessions/$(sessionId)).data
        && get(/databases/$(database)/documents/sessions/$(sessionId)).data.attendeeIds.hasAny(myCamperIds());
    }

    // Whether the given album doc is linked to a session with the parent's camper.
    function albumLinkedToMyCamper(albumData) {
      return 'linkedSessionId' in albumData && sessionHasMyCamper(albumData.linkedSessionId);
    }

    match /userDirectory/{pageId} {
      allow read, write: if isStaffOrAdmin();
    }

    match /users/{userId} {
      // Any signed-in user may read their own user doc (needed to resolve a
      // parent's camper ids); only staff/admin may read others or write.
      allow read: if isStaffOrAdmin() || (isAuthenticated() && userId == myCampminderId());
      allow write: if isStaffOrAdmin();
    }

    // Sessions collection
    match /sessions/{sessionId} {
      // Parents may read a session doc only if one of their campers attends it
      // (so they can discover the linked album). Subcollections stay staff/admin.
      allow read: if isStaffOrAdmin()
        || (isParent() && 'attendeeIds' in resource.data && resource.data.attendeeIds.hasAny(myCamperIds()));
      allow write: if isStaffOrAdmin();
      
      // Sections subcollection
      match /sections/{sectionId} {
        allow read: if isStaffOrAdmin();
        allow create, update, delete: if isStaffOrAdmin();
        
        // Section schedules subcollection
        match /schedule/{scheduleId} {
          allow read: if isStaffOrAdmin();
          allow create, update, delete: if isStaffOrAdmin();
        }
      }
      
      // Other subcollections
      match /attendees/{attendeeId} {
        allow read: if isStaffOrAdmin();
        allow write: if isStaffOrAdmin();
      }
      
      match /bunks/{bunkId} {
        allow read: if isStaffOrAdmin();
        allow write: if isStaffOrAdmin();
      }
      
      match /nightSchedules/{shiftId} {
        allow read: if isStaffOrAdmin();
        allow write: if isStaffOrAdmin();
      }
      
      match /freeplays/{freeplayId} {
        allow read: if isStaffOrAdmin();
        allow write: if isStaffOrAdmin();
      }
    }
    
    // Albums collection
    match /albums/{albumId} {
      allow read: if isStaffOrAdmin() || isPhotographer()
        || (isParent() && albumLinkedToMyCamper(resource.data));
      allow write: if isStaffOrAdmin() || isPhotographer();

      match /albumItems/{albumItemId} {
        allow read: if isStaffOrAdmin() || isPhotographer()
          || (isParent() && albumLinkedToMyCamper(get(/databases/$(database)/documents/albums/$(albumId)).data));
        allow write: if isStaffOrAdmin() || isPhotographer();
      }
    }

    // User collections
    match /campers/{camperId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    match /parents/{parentId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    match /staff/{staffId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    match /admins/{adminId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    match /photographers/{photographerId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    // Shared resources
    match /programAreas/{areaId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
    
    match /posts/{postId} {
      allow read: if isStaffOrAdmin();
      allow write: if isStaffOrAdmin();
    }
  }
}