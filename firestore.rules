rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'ADMIN';
    }

    function isStaff() {
      return isSignedIn() && request.auth.token.role == 'STAFF';
    }

    // Users are keyed by their Campminder ID, exposed on the token as a custom claim.
    function currentPersonId() {
      return request.auth.token.campminderId;
    }

    // Attendees of a session are stored as documents in its `attendees`
    // subcollection, keyed by Campminder ID.
    function isAttendee(sessionId, personId) {
      return exists(/databases/$(database)/documents/sessions/$(sessionId)/attendees/$(personId));
    }

    function isSectionPublished(sessionId, sectionId) {
      return get(/databases/$(database)/documents/sessions/$(sessionId)/sections/$(sectionId)).data.get('isPublished', false) == true;
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin() || (isStaff() && isAttendee(sessionId, currentPersonId()));
      allow write: if isAdmin();

      match /sections/{sectionId} {
        allow read: if isAdmin() || (isStaff() && isAttendee(sessionId, currentPersonId()));
        allow write: if isAdmin();

        match /schedule/{scheduleId} {
          allow read: if isAdmin() || (isStaff() && isAttendee(sessionId, currentPersonId()) && isSectionPublished(sessionId, sectionId));
          allow write: if isAdmin();
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}