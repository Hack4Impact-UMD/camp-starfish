{
  "compilerOptions": {
    "lib": ["es2017"],
    "module": "commonjs",
    "composite": true,
    "esModuleInterop": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "strict": true,
    "target": "es2017",
    "paths": {
      "@/*": ["../src/*"]
    },
    "skipLibCheck": true
  },
  "compileOnSave": true,
  "include": ["src"]
}
